// Counterexamples for predicate permission amounts obtained through quantified
// permissions. A single quantified permission over the sequence `s` (with
// s[0] == a) contributes 1/2 to the predicate instance P(a), and that amount is
// reported when full permission to P(a) is asserted.
//
// See also qpred.vpr (quantified predicate permissions from two sources).

field f: Int
predicate P(this: Ref) { acc(this.f) }

method qp_predicate_permission(s: Seq[Ref], a: Ref)
  requires |s| > 0 && s[0] == a
  requires forall j: Int, k: Int :: 0 <= j < k < |s| ==> s[j] != s[k]
  requires forall j: Int :: 0 <= j < |s| ==> acc(P(s[j]), 1/2)
{
  //:: ExpectedCounterexample(assert.failed:insufficient.permission, (acc(P(a), 1/2)))
  assert acc(P(a), 1/1)
}
