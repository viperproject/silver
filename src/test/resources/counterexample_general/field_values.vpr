// Counterexamples for heap values: the value stored at a field location is
// reported for a single field, several fields of one object, and the same
// field of two distinct objects.

field f: Int
field g: Int

method single_field(x: Ref)
  requires acc(x.f)
  requires x.f == 99
{
  //:: ExpectedCounterexample(assert.failed:assertion.false, (x.f == 99))
  assert x.f != 99
}

method two_fields(x: Ref)
  requires acc(x.f) && acc(x.g)
  requires x.f == 3 && x.g == 8
{
  //:: ExpectedCounterexample(assert.failed:assertion.false, (x.f == 3, x.g == 8))
  assert x.f == x.g
}

method two_objects(x: Ref, y: Ref)
  requires acc(x.f) && acc(y.f)
  requires x != y
  requires x.f == 1 && y.f == 2
{
  //:: ExpectedCounterexample(assert.failed:assertion.false, (x.f == 1, y.f == 2))
  assert x.f == y.f
}
