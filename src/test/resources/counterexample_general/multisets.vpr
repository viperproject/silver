// Counterexamples for (heap-independent) multiset values. Multiset contents are
// compared as whole values between two variables constrained to be equal.

method multiset_eq(s: Multiset[Int], t: Multiset[Int])
  requires s == t
{
  //:: ExpectedCounterexample(assert.failed:assertion.false, (s == t))
  assert s != t
}
