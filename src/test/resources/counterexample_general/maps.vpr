// Counterexamples for (heap-independent) map values. Map contents are compared
// as whole values between two variables that the model constrains to be equal.

method map_eq(s: Map[Int, Int], t: Map[Int, Int])
  requires s == t
{
  //:: ExpectedCounterexample(assert.failed:assertion.false, (s == t))
  assert s != t
}
