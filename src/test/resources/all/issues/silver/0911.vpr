predicate buggy(self: Ref) {
  //:: ExpectedOutput(consistency.error)
  exists b: Bool :: { foo(self) } foo(self) == b
}

domain Buggy {
  function bar(Int): Int
  axiom buggy_ax {
    //:: ExpectedOutput(consistency.error)
    exists n: Int :: { bar(42) } n == 42
  }
}

function foo(x: Ref): Bool